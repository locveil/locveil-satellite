#!/bin/sh
# Locveil pre-commit hook: scope-guard (ledger-discipline.md §4) + contract-guard +
# the esp32-site owner guard (contracts.md §4) — all --check only, hooks never mutate
# the tree. Install once:  git config core.hooksPath hooks
python3 scripts/scope_guard.py --config .scope-guard.toml --check || exit 1
# --relax-tags: HK-12 mid-bump tolerance — a bump commit cannot carry its own tag, so
# TAG-MISSING/ORPHAN-TAG warn locally; CI runs strict and the pushed tag satisfies it.
python3 scripts/contract_guard.py --check --relax-tags || exit 1
python3 scripts/check_esp32_site.py || exit 1
exec python3 scripts/check_docs_manifest.py

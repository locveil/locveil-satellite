# ESP32 fleet provisioning + asset serving (ARCH-22 Plane B).
# MANAGED BY ANSIBLE — do not edit by hand (see nginx/ansible/templates/esp32-site.conf.j2).
#
# Path mapping: web root is {{ esp32_web_root }} (the parent of {{ esp32_srv_dir }}), so a URL
# /esp32/<x> maps to the file {{ esp32_srv_dir }}/<x> with no alias juggling.

# --- :{{ esp32_http_port | default(8081) }}  provisioning bootstrap (PUBLIC artifacts; human approval is the gate)
# A DEDICATED port (default 8081), not :80 — the WB admin UI lives on this same nginx's :80,
# and a shared-:80 server block claiming the bare IP would steal it (ARCH-41).
server {
    listen {{ esp32_http_port | default(8081) }};
    server_name {{ esp32_server_name }};

    # public CA cert — the device fetches it to trust the server
    location = /esp32/provision/ca.crt {
        root {{ esp32_web_root }};
        default_type application/x-pem-file;
    }

    # device submits its CSR (PUT) and polls for the signed cert (GET, 404 until approved)
    location /esp32/provision/pending/ {
        root {{ esp32_web_root }};
        dav_methods PUT;
        create_full_put_path on;
        dav_access user:rw group:rw all:r;
        client_max_body_size 16k;
        limit_except GET PUT { deny all; }
    }
    location /esp32/provision/cert/ {
        root {{ esp32_web_root }};
        limit_except GET { deny all; }
    }

    # everything else on :80 is not part of this plane
    location / { return 404; }
}

# --- :{{ esp32_https_port | default(443) }}  operational zone (mTLS — only provisioned devices) --
server {
    listen {{ esp32_https_port | default(443) }} ssl http2;
    server_name {{ esp32_server_name }};

    ssl_certificate        {{ esp32_ca_dir }}/server.crt;
    ssl_certificate_key    {{ esp32_ca_dir }}/server.key;
    ssl_client_certificate {{ esp32_ca_dir }}/ca.crt;
    ssl_verify_client      on;                 # mTLS: device must present a CA-signed client cert
    ssl_protocols          TLSv1.2 TLSv1.3;

    # OTA firmware images + per-node model packs (static; operator/CI publishes the files)
    location /esp32/firmware/ {
        root {{ esp32_web_root }};
        limit_except GET { deny all; }
    }
    location /esp32/models/ {
        root {{ esp32_web_root }};
        limit_except GET { deny all; }
    }

{% if esp32_irene_upstream %}
    # Irene's WS, reverse-proxied behind mTLS (only if Irene runs on THIS controller).
    location /ws/ {
        proxy_pass http://{{ esp32_irene_upstream }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Client-Cert-DN $ssl_client_s_dn;   # the device identity (full subject DN), verified by mTLS
        proxy_read_timeout 3600s;
    }
{% endif %}

    location / { return 404; }
}

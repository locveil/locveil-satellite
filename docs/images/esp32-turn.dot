// Irene — one turn from an ESP32 voice satellite. Render:
//   dot -Tpng docs/images/esp32-turn.dot -o docs/images/esp32-turn.png
digraph esp32_turn {
  rankdir=LR; bgcolor="white"; splines=spline; nodesep=0.35; ranksep=0.7;
  fontname="Helvetica"; labelloc=t; fontsize=14;
  label="A satellite turn: a thin device, one brain — Irene's side (transport + identity + spoken reply) is built; the firmware is the remaining piece";
  node [fontname="Helvetica", fontsize=10, shape=box, style="filled,rounded", penwidth=1.4];
  edge [fontname="Helvetica", fontsize=9, color="#9e9e9e", arrowsize=0.7];

  reg    [label="connect + register (once)\nroom(s) + devices + audio capability → identity", fillcolor="#e3f2fd", color="#1976d2"];
  wake   [label="ESP32\non-device wake word fires", fillcolor="#f3e5f5", color="#7b1fa2"];
  stream [label="stream mic audio (PCM)\nover WS  /ws/audio", fillcolor="#f3e5f5", color="#7b1fa2"];
  brain  [label="Irene  /ws/audio\nASR → NLU → intent", fillcolor="#e8f5e8", color="#388e3c"];
  ack    [label="status ack: text\n(input socket)", fillcolor="#e3f2fd", color="#1976d2"];
  reply  [label="Irene streams TTS audio back\nconformed to the device  /ws/audio/reply", fillcolor="#e8f5e8", color="#388e3c"];
  speak  [label="ESP32 plays the reply\n(firmware pending)", fillcolor="#f5f5f5", color="#9e9e9e"];

  reg -> wake -> stream -> brain;
  brain -> ack;
  brain -> reply [label="spoken reply"];
  reply -> speak [style=dashed, label="firmware"];
}
